{
  "mcpServers": {
    "camunda-mcp": {
      "command": "uv",
      "args": [
        "run",
        "camunda-mcp"
      ],
      "env": {
        "FASTMCP_LOG_LEVEL": "<YOUR_FASTMCP_LOG_LEVEL>",
        "NO_COLOR": "<YOUR_NO_COLOR>",
        "TERM": "<YOUR_TERM>",
        "AGENT_DESCRIPTION": "<YOUR_AGENT_DESCRIPTION>",
        "AGENT_SYSTEM_PROMPT": "<YOUR_AGENT_SYSTEM_PROMPT>",
        "DEFAULT_AGENT_NAME": "<YOUR_DEFAULT_AGENT_NAME>",
        "MCP_URL": "<YOUR_MCP_URL>",
        "CAMUNDA_PLATFORM": "<YOUR_CAMUNDA_PLATFORM>",
        "CAMUNDA_SSL_VERIFY": "<YOUR_CAMUNDA_SSL_VERIFY>",
        "CAMUNDA7_URL": "<YOUR_CAMUNDA7_URL>",
        "CAMUNDA7_TOKEN": "<YOUR_CAMUNDA7_TOKEN>",
        "CAMUNDA7_USERNAME": "<YOUR_CAMUNDA7_USERNAME>",
        "CAMUNDA7_PASSWORD": "<YOUR_CAMUNDA7_PASSWORD>",
        "CAMUNDA8_ZEEBE_REST_URL": "<YOUR_CAMUNDA8_ZEEBE_REST_URL>",
        "CAMUNDA8_OPERATE_URL": "<YOUR_CAMUNDA8_OPERATE_URL>",
        "CAMUNDA8_TASKLIST_URL": "<YOUR_CAMUNDA8_TASKLIST_URL>",
        "CAMUNDA8_CLIENT_ID": "<YOUR_CAMUNDA8_CLIENT_ID>",
        "CAMUNDA8_CLIENT_SECRET": "<YOUR_CAMUNDA8_CLIENT_SECRET>",
        "CAMUNDA8_OAUTH_URL": "<YOUR_CAMUNDA8_OAUTH_URL>",
        "CAMUNDA8_AUDIENCE": "<YOUR_CAMUNDA8_AUDIENCE>",
        "CAMUNDATOOL": "True"
      }
    }
  }
}
