        "CAMUNDA8_OAUTH_URL": "https://login.cloud.camunda.io/oauth/token",
        "CAMUNDA8_OPERATE_URL": "http://localhost:8081",
        "CAMUNDA8_TASKLIST_URL": "http://localhost:8082",
        "CAMUNDA8_ZEEBE_REST_URL": "http://localhost:8080",
