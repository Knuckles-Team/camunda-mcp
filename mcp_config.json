{
  "mcpServers": {
    "camunda-mcp": {
      "command": "uv",
      "args": [
        "run",
        "camunda-mcp"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "CAMUNDA7_PASSWORD": "changeme",
